{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A fresh produce item available for purchase.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the product" },
        "description": { "type": "string", "description": "Detailed description of the product" },
        "price": { "type": "number", "description": "Price per unit (kg, bunch, etc.)" },
        "category": { "type": "string", "enum": ["Fruits", "Vegetables", "Leafy Greens", "Organic", "Exotic Fruits", "Organic Products"] },
        "imageUrl": { "type": "string", "format": "uri", "description": "URL to the product image" },
        "unit": { "type": "string", "description": "Unit of measurement (e.g., kg, 250g, bunch)" },
        "stock": { "type": "number", "description": "Available quantity in stock" },
        "isOrganic": { "type": "boolean", "description": "Whether the product is organic" }
      },
      "required": ["name", "price", "category", "imageUrl", "unit"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order containing multiple products.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the user who placed the order" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "address": {
          "type": "object",
          "properties": {
            "street": { "type": "string" },
            "city": { "type": "string" },
            "state": { "type": "string" },
            "pincode": { "type": "string" }
          }
        },
        "paymentMethod": { "type": "string", "enum": ["COD", "UPI"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "totalAmount", "status", "address", "paymentMethod", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "address": {
          "type": "object",
          "properties": {
            "street": { "type": "string" },
            "city": { "type": "string" },
            "state": { "type": "string" },
            "pincode": { "type": "string" }
          }
        },
        "role": { "type": "string", "enum": ["customer", "admin"] }
      },
      "required": ["name", "email"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of fresh produce products."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of customer orders."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    }
  }
}
